# Monitoring target
WEBSITE_URL=https://craftboard.online
BOT_SYSTEMD_SERVICE=tg-poll-bot
BOT_ENV_FILE=/opt/bot_tg/.env
MONITOR_NAME=vps-craftboard
MONITOR_TARGETS_FILE=/opt/bot_tg/monitor_targets.json

# Repo names for fallback mode (when MONITOR_TARGETS_FILE is not used)
WEBSITE_REPO=keastayer-cell/craftboard-site
BOT_REPO=keastayer-cell/tg-poll-bot

# Simplest notifications (Telegram)
# If empty, monitor will try ADMIN_ID from BOT_ENV_FILE.
ALERT_BOT_TOKEN=
ALERT_TELEGRAM_CHAT_ID=

# Email alerts (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USERNAME=you@example.com
SMTP_PASSWORD=app_password_here
SMTP_TLS=1
ALERT_FROM=you@example.com
ALERT_TO=you@example.com

# Runtime
HTTP_TIMEOUT=10
MONITOR_STATE_FILE=/var/lib/uptime-monitor/state.json
